<?xml version="1.0" encoding="UTF-8"?>
<suite name="SauceDemo Sequential Suite" parallel="false">
    <listeners>
        <listener class-name="com.example.saucedemo.utils.RetryListener"/>
    </listeners>
    <test name="SequentialTests">
        <classes>
            <class name="com.example.saucedemo.tests.PurchaseSingleItemTest"/>
            <class name="com.example.saucedemo.tests.PurchaseMultipleItemsTest"/>
            <class name="com.example.saucedemo.tests.LockedOutUserLoginNegativeTest"/>
            <class name="com.example.saucedemo.tests.CheckoutMissingPostalCodeNegativeTest"/>
            <class name="com.example.saucedemo.tests.ResetAppStateClearsCartTest"/>
        </classes>
    </test>
</suite>
